# ─── FarmConnect Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to git.

# ── Supabase (Required) ───────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Security Notes ────────────────────────────────────────────────
# 1. VITE_SUPABASE_ANON_KEY is safe to expose in browser (it is public by design).
#    Row Level Security (RLS) in Supabase-schema.sql protects your data.
# 2. NEVER expose your service_role key in the frontend. It bypasses RLS.
# 3. Rotate your anon key if you suspect it has been compromised:
#    Supabase Dashboard → Settings → API → Regenerate Keys
